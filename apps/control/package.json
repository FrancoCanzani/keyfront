{
  "name": "control",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"bun run --hot src/server/index.ts\"",
    "build": "tsc -b && vite build",
    "start": "bun run src/server/index.ts",
    "typecheck": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "lucide-react": "^1.23.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
