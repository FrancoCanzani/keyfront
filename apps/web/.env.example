# better-auth
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:5173

# Cloudflare Email Sending (REST API). Leave unset in dev — magic links are
# printed to the server console instead. The EMAIL_FROM domain must be
# onboarded first: npx wrangler email sending enable <domain>
CF_ACCOUNT_ID=
CF_EMAIL_API_TOKEN=
EMAIL_FROM=
