# Gateway
ADDR=:8080

# Host suffix consumers call: {host_key}.{GATEWAY_DOMAIN}. Prod: gw.yourdomain.com
GATEWAY_DOMAIN=localhost

# Injected as X-Gateway-Secret so origins can verify traffic came from us
GATEWAY_SECRET=dev-secret

# Postgres — local (dev). Swap for PlanetScale at deploy.
DATABASE_URL=postgres://YOUR_USER@localhost/api_gateway

# PlanetScale URL; only read by `bun run db:migrate:prod` (deploy step)
DATABASE_URL_PROD=

# Redis — local (dev). Self-hosted on Hetzner at deploy.
REDIS_URL=redis://localhost:6379
